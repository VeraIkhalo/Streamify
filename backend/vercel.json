{
  "version": 2,
  "buildCommand": "npm install",
  "env": {
    "MONGO_URI": "@MONGO_URI",
    "JWT_SECRET_KEY": "@JWT_SECRET_KEY",
    "STREAM_API_KEY": "@STREAM_API_KEY",
    "STREAM_API_SECRET": "@STREAM_API_SECRET",
    "EMAIL_USER": "@EMAIL_USER",
    "EMAIL_PASSWORD": "@EMAIL_PASSWORD",
    "CLIENT_URL": "@CLIENT_URL"
  },
  "functions": {
    "api/index.js": {
      "runtime": "nodejs18.x"
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/api/index.js"
    }
  ]
}
